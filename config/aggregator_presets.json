  "REQUIRED_SCORE_MODIFIER": {
    "_comment": "Phase 2: Livermore state-conditional threshold deltas. Applied additively to BOTH buy and sell thresholds after regime-adjusted thresholds are computed. Full retest-type modifiers (CLEAN/BREAKOUT/WICK/CHASE_SOFT/CHASE_HARD) are wired in Phase 3B. SECONDARY states raise the bar — entries still allowed but harder to clear. NATURAL states are gated by the Hard Veto + Gatekeeper HOLD before reaching this modifier.",
    "state_modifiers": {
      "MAIN_UP": 0.0,
      "MAIN_DOWN": 0.0,
      "NATURAL_RETRACEMENT": 0.0,
      "NATURAL_REBOUND": 0.0,
      "SECONDARY_RETRACEMENT": 0.4,
      "SECONDARY_REBOUND": 0.4
    },
    "modifier_cap": 1.5,
    "vtm_circuit_breaker_atr_mult": 3.0,
    "vol_down_ratio_veto_threshold": 1.2,
    "_note": "All numeric thresholds live here per MRS zero-magic-numbers rule."
  },
  "MR_THREE_MODE": {
    "_comment": "Phase 3A: MR Three-Mode Rebuild thresholds. Zero magic numbers — all constants here. Mode 1 = Pullback Completion (NATURAL_RETRACEMENT, spring mandatory). Mode 2 = Counter-Trend (SECONDARY states, ADX<25, 4/4 optional). Mode 3 = Climax Fade (MAIN states, stretched leg + reversal candle).",
    "mode1": {
      "_comment": "Pullback Completion — NATURAL_RETRACEMENT, LONG only.",
      "spring_min_penetration": 0.005,
      "spring_max_penetration": 0.05,
      "spring_recovery_max_bars": 3,
      "spring_swing_lookback": 20,
      "vol_contraction_avg_pct": 0.8,
      "vol_spike_max_pct": 1.5,
      "bb_lower_zone_threshold": 0.2,
      "ma_proximity_atr_mult": 0.5,
      "optional_min_count": 2,
      "vol_down_ratio_veto": 1.2,
      "btc_ema200_4h_modifier": -0.1
    },
    "mode2": {
      "_comment": "Counter-Trend — SECONDARY states only. SECONDARY_RETRACEMENT→LONG, SECONDARY_REBOUND→SHORT.",
      "adx_max": 25,
      "optional_min_count": 4,
      "bb_inside_required": true,
      "btc_long_zscore_threshold": -2.0,
      "btc_short_zscore_threshold": 3.5
    },
    "mode3": {
      "_comment": "Climax Fade — MAIN states. MAIN_UP→SHORT, MAIN_DOWN→LONG. Target is EMA20, NOT a reversal call.",
      "leg_stretch_ratio_min": 1.5,
      "leg_stretch_window": 10,
      "leg_stretch_lookback": 50,
      "price_anchor_atr_mult": 2.5,
      "require_above_avg_volume": true,
      "volume_avg_lookback": 20
    },
    "bb_kc_squeeze": {
      "_comment": "BB(20,2σ) inside Keltner(20 EMA, 1.5×ATR14) for 5+ bars. bbw_percentile bottom 30th = compressed volatility.",
      "min_squeeze_bars": 5,
      "bbw_percentile_threshold": 30.0,
      "kc_ema_period": 20,
      "kc_atr_mult": 1.5
    },
    "nr7_lookback": 7
  },
