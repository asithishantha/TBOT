      "major_mult": 3.5,
      "minor_mult": 1.0,
      "dual_confirm": 2,
      "atr_period": 14,
      "_calibration": "BTC 4H Jan2024–Feb2026: 1.48 transitions/week, 5/6 turning-point score"
    },
    "GOLD": {
      "major_mult": 4.0,
